#!/usr/bin/env python

from __future__ import annotations

import argparse
import os
import re
import urllib.request
import warnings
from pathlib import Path

from dotenv import load_dotenv
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.runnables import RunnablePassthrough
from langchain_text_splitters import HTMLHeaderTextSplitter
from langchain_text_splitters import RecursiveCharacterTextSplitter

warnings.filterwarnings(
    "ignore",
    message="`langchain-community` is being sunset*",
    category=DeprecationWarning,
)
from langchain_community.vectorstores import FAISS

from lmstudio_config import make_embeddings
from lmstudio_config import make_llm
from lmstudio_config import print_lmstudio_check
from lmstudio_config import require_lmstudio_ready
from lmstudio_config import response_to_text


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_DATA_DIRECTORIES = [
    ROOT / "data/basic-rules/www.dndbeyond.com/sources",
    ROOT / "data/basic-rules/www.dndbeyond.com/compendium/rules/basic-rules",
]
EXIT_COMMANDS = {"exit", "quit"}
EMPTY_ANSWER_MESSAGE = (
    "The chat model returned an empty answer. Try "
    "./scripts/dnd-beyond-basic --check-lmstudio, or switch "
    "LMSTUDIO_CHAT_MODEL to a chat-capable instruct model."
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Ask questions about D&D basic rules.")
    parser.add_argument(
        "--check-lmstudio",
        action="store_true",
        help="Check the local LM Studio OpenAI-compatible server and exit.",
    )
    return parser.parse_args()


def get_data_directories() -> list[Path]:
    configured = os.getenv("DNDGENIE_DATA_DIRS")
    if configured:
        return [
            Path(path).expanduser().resolve()
            for path in configured.split(os.pathsep)
            if path
        ]

    return DEFAULT_DATA_DIRECTORIES


def fetch_url_text(url: str) -> str:
    request = urllib.request.Request(
        url,
        headers={"User-Agent": "DnDGenie/1.0"},
    )
    with urllib.request.urlopen(request, timeout=30) as response:
        charset = response.headers.get_content_charset() or "utf-8"
        return response.read().decode(charset, errors="replace")


def load_source(source: str | Path):
    headers_to_split_on = [
        ("h1", "Header 1"),
        ("h2", "Header 2"),
        ("h3", "Header 3"),
        ("h4", "Header 4"),
    ]

    html_splitter = HTMLHeaderTextSplitter(headers_to_split_on=headers_to_split_on)
    source_text = str(source)
    if re.match(r"https?://", source_text):
        html_header_splits = html_splitter.split_text(fetch_url_text(source_text))
    else:
        html_header_splits = html_splitter.split_text_from_file(source_text)

    text_splitter = RecursiveCharacterTextSplitter(
        chunk_size=1024,
        chunk_overlap=128,
    )

    splits = text_splitter.split_documents(html_header_splits)
    for split in splits:
        split.metadata["source"] = source_text
    return splits


def load_data_files(directory: Path):
    splits = []
    for filepath in sorted(directory.iterdir()):
        if not filepath.is_file() or filepath.name == "spells":
            continue

        print(f"Loading {filepath}")
        splits += load_source(filepath)
    return splits


def load_corpus():
    all_splits = []
    for directory in get_data_directories():
        all_splits += load_data_files(directory)
    return all_splits


def format_docs(docs) -> str:
    return "\n\n".join(doc.page_content for doc in docs)


def make_chain(retriever, llm):
    prompt = ChatPromptTemplate.from_messages(
        [
            (
                "system",
                "You are a helpful tabletop RPG assistant. Use the retrieved "
                "D&D rules context when it is relevant. If the user asks for "
                "an encounter, treasure, or other table-ready play aid, provide "
                "a concise practical answer.",
            ),
            (
                "human",
                "Question: {question}\n\nContext:\n{context}\n\nAnswer:",
            ),
        ]
    )

    return (
        {"context": retriever | format_docs, "question": RunnablePassthrough()}
        | prompt
        | llm
    )


def show(text: str) -> None:
    sentences = re.split(r"(?<=[.!?]) +", text)
    for sentence in sentences:
        print(sentence.strip())
        print()


class DnDGenie:
    def __init__(self, splits, settings):
        self.embeddings = make_embeddings(settings)
        self.llm = make_llm(settings)
        self.vector_store = FAISS.from_documents(splits, embedding=self.embeddings)
        self.rebuild_chain()

    def rebuild_chain(self) -> None:
        self.retriever = self.vector_store.as_retriever()
        self.chain = make_chain(self.retriever, self.llm)

    def add_source(self, source: str) -> None:
        splits = load_source(source)
        self.vector_store.add_documents(splits)
        self.rebuild_chain()

    def answer(self, question: str) -> str:
        answer = response_to_text(self.chain.invoke(question))
        return answer or EMPTY_ANSWER_MESSAGE


def main() -> None:
    load_dotenv()
    args = parse_args()
    if args.check_lmstudio:
        print_lmstudio_check()
        return

    try:
        settings = require_lmstudio_ready()
    except RuntimeError as exc:
        raise SystemExit(str(exc)) from exc

    all_splits = load_corpus()
    genie = DnDGenie(all_splits, settings)

    while True:
        try:
            got = input("input> ").strip()
            if not got:
                continue
            if got.lower() in EXIT_COMMANDS:
                break

            match = re.match(r"load\((.*)\)", got)
            if match:
                genie.add_source(match.group(1))
            else:
                print("Thinking...", flush=True)
                show(genie.answer(got))

        except EOFError:
            break


if __name__ == "__main__":
    main()
